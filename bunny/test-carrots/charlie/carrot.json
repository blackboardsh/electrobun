{
  "id": "charlie",
  "name": "Charlie",
  "version": "0.0.1",
  "description": "A visible Carrot with a tiny counter, notifications, and its own Bun worker.",
  "mode": "window",
  "permissions": {
    "host": {
      "windows": true,
      "notifications": true,
      "storage": true
    },
    "bun": {
      "read": true,
      "write": true
    },
    "isolation": "shared-worker"
  },
  "view": {
    "relativePath": "views/index.html",
    "title": "Charlie Carrot",
    "width": 440,
    "height": 520
  },
  "worker": {
    "relativePath": "worker.js"
  }
}
