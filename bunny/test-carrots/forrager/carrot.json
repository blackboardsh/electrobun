{
  "id": "forrager",
  "name": "Forrager",
  "version": "0.0.1",
  "description": "A background Carrot that runs from the tray and keeps a tiny hidden controller webview alive.",
  "mode": "background",
  "permissions": {
    "host": {
      "tray": true,
      "notifications": true,
      "storage": true
    },
    "bun": {
      "read": true,
      "write": true
    },
    "isolation": "shared-worker"
  },
  "view": {
    "relativePath": "views/index.html",
    "title": "Forrager Background Controller",
    "width": 320,
    "height": 220,
    "hidden": true
  },
  "worker": {
    "relativePath": "worker.js"
  }
}
