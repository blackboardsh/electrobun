{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "types": []
  },
  "include": ["web/**/*.ts", "web/**/*.tsx", "worker.ts", "build.ts"]
}
