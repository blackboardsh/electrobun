{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": ["bun", "node"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["web/**/*", "workspace-lenses-overlay.*"]
}
