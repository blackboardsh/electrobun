{
  "id": "bunny-dash",
  "name": "Bunny Dash",
  "version": "0.0.1",
  "description": "A Colab-shaped Bunny Dash shell for managing local and remote Bunny Ears instances.",
  "mode": "background",
  "permissions": {
    "host": {
      "windows": true,
      "storage": true,
      "tray": true
    },
    "bun": {
      "read": true,
      "write": true,
      "run": true,
      "env": true,
      "ffi": true
    },
    "isolation": "shared-worker"
  },
  "view": {
    "relativePath": "views/index.html",
    "title": "Bunny Dash",
    "width": 1480,
    "height": 920,
    "titleBarStyle": "hiddenInset",
    "hidden": true
  },
  "worker": {
    "relativePath": "worker.js"
  }
}
