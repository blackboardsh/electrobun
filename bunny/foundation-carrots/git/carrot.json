{
  "id": "bunny.git",
  "name": "Bunny Git",
  "version": "0.0.1",
  "description": "First-party git carrot scaffold for Bunny Dash and other carrots.",
  "mode": "background",
  "permissions": {
    "host": {
      "storage": true
    },
    "bun": {
      "read": true,
      "write": true,
      "run": true
    },
    "isolation": "shared-worker"
  },
  "view": {
    "relativePath": "views/index.html",
    "title": "Bunny Git",
    "width": 320,
    "height": 220,
    "hidden": true
  },
  "worker": {
    "relativePath": "worker.js"
  }
}
